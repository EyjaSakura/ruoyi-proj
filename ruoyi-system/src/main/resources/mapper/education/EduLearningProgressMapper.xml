<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.education.EduLearningProgressMapper">

    <resultMap type="com.ruoyi.system.domain.education.EduLearningProgress" id="EduLearningProgressResult">
        <id property="progressId" column="progress_id" />
        <result property="courseId" column="course_id" />
        <result property="chapterId" column="chapter_id" />
        <result property="studentUserId" column="student_user_id" />
        <result property="learnMinutes" column="learn_minutes" />
        <result property="progressPercent" column="progress_percent" />
        <result property="completedFlag" column="completed_flag" />
        <result property="firstStudyTime" column="first_study_time" />
        <result property="lastStudyTime" column="last_study_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectEduLearningProgressVo">
        select
            t.progress_id,
            t.course_id,
            t.chapter_id,
            t.student_user_id,
            t.learn_minutes,
            t.progress_percent,
            t.completed_flag,
            t.first_study_time,
            t.last_study_time,
            t.create_by,
            t.create_time,
            t.update_by,
            t.update_time,
            t.remark
        from edu_learning_progress t
    </sql>

    <select id="selectEduLearningProgressList" parameterType="com.ruoyi.system.domain.education.EduLearningProgress" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        <where>
            <if test="params.scopeDenyAll != null"> and 1 = 0</if>
            <if test="courseId != null"> and t.course_id = #{courseId}</if>
            <if test="studentUserId != null"> and t.student_user_id = #{studentUserId}</if>
            <if test="completedFlag != null and completedFlag != ''"> and t.completed_flag = #{completedFlag}</if>
            <if test="params.scopeDeptId != null">
                and exists (
                    select 1
                    from edu_course c
                    where c.course_id = t.course_id
                      and c.dept_id = #{params.scopeDeptId}
                      and (c.del_flag is null or c.del_flag = '0')
                )
            </if>
            <if test="params.scopeTeacherUserId != null">
                and exists (
                    select 1
                    from edu_course_teacher ct
                    where ct.course_id = t.course_id
                      and ct.teacher_user_id = #{params.scopeTeacherUserId}
                )
            </if>
        </where>
        order by t.progress_id desc
    </select>

    <select id="selectEduLearningProgressByProgressId" parameterType="Long" resultMap="EduLearningProgressResult">
        <include refid="selectEduLearningProgressVo"/>
        where t.progress_id = #{progressId}
    </select>

    <insert id="insertEduLearningProgress" parameterType="com.ruoyi.system.domain.education.EduLearningProgress" useGeneratedKeys="true" keyProperty="progressId">
        insert into edu_learning_progress
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseId != null">course_id,</if>
            <if test="chapterId != null">chapter_id,</if>
            <if test="studentUserId != null">student_user_id,</if>
            <if test="learnMinutes != null">learn_minutes,</if>
            <if test="progressPercent != null">progress_percent,</if>
            <if test="completedFlag != null">completed_flag,</if>
            <if test="firstStudyTime != null">first_study_time,</if>
            <if test="lastStudyTime != null">last_study_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseId != null">#{courseId},</if>
            <if test="chapterId != null">#{chapterId},</if>
            <if test="studentUserId != null">#{studentUserId},</if>
            <if test="learnMinutes != null">#{learnMinutes},</if>
            <if test="progressPercent != null">#{progressPercent},</if>
            <if test="completedFlag != null">#{completedFlag},</if>
            <if test="firstStudyTime != null">#{firstStudyTime},</if>
            <if test="lastStudyTime != null">#{lastStudyTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateEduLearningProgress" parameterType="com.ruoyi.system.domain.education.EduLearningProgress">
        update edu_learning_progress
        <trim prefix="SET" suffixOverrides=",">
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="chapterId != null">chapter_id = #{chapterId},</if>
            <if test="studentUserId != null">student_user_id = #{studentUserId},</if>
            <if test="learnMinutes != null">learn_minutes = #{learnMinutes},</if>
            <if test="progressPercent != null">progress_percent = #{progressPercent},</if>
            <if test="completedFlag != null">completed_flag = #{completedFlag},</if>
            <if test="firstStudyTime != null">first_study_time = #{firstStudyTime},</if>
            <if test="lastStudyTime != null">last_study_time = #{lastStudyTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where progress_id = #{progressId}
    </update>

    <delete id="deleteEduLearningProgressByProgressId" parameterType="Long">
        delete from edu_learning_progress where progress_id = #{progressId}
    </delete>

    <delete id="deleteEduLearningProgressByProgressIds" parameterType="long">
        delete from edu_learning_progress where progress_id in
        <foreach item="progressId" collection="array" open="(" separator="," close=")">
            #{progressId}
        </foreach>
    </delete>
</mapper>
