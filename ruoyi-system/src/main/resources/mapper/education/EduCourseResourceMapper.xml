<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.education.EduCourseResourceMapper">

    <resultMap type="com.ruoyi.system.domain.education.EduCourseResource" id="EduCourseResourceResult">
        <id property="resourceId" column="resource_id" />
        <result property="courseId" column="course_id" />
        <result property="chapterId" column="chapter_id" />
        <result property="resourceTitle" column="resource_title" />
        <result property="resourceType" column="resource_type" />
        <result property="fileName" column="file_name" />
        <result property="fileUrl" column="file_url" />
        <result property="fileSuffix" column="file_suffix" />
        <result property="fileSize" column="file_size" />
        <result property="downloadCount" column="download_count" />
        <result property="uploadUserId" column="upload_user_id" />
        <result property="orderNum" column="order_num" />
        <result property="status" column="status" />
        <result property="delFlag" column="del_flag" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectEduCourseResourceVo">
        select
            t.resource_id,
            t.course_id,
            t.chapter_id,
            t.resource_title,
            t.resource_type,
            t.file_name,
            t.file_url,
            t.file_suffix,
            t.file_size,
            t.download_count,
            t.upload_user_id,
            t.order_num,
            t.status,
            t.del_flag,
            t.create_by,
            t.create_time,
            t.update_by,
            t.update_time,
            t.remark
        from edu_course_resource t
    </sql>

    <select id="selectEduCourseResourceList" parameterType="com.ruoyi.system.domain.education.EduCourseResource" resultMap="EduCourseResourceResult">
        <include refid="selectEduCourseResourceVo"/>
        <where>
            <if test="params.scopeDenyAll != null"> and 1 = 0</if>
            and (t.del_flag is null or t.del_flag = '0')
            <if test="courseId != null"> and t.course_id = #{courseId}</if>
            <if test="resourceTitle != null and resourceTitle != ''"> and t.resource_title like concat('%', #{resourceTitle}, '%')</if>
            <if test="resourceType != null and resourceType != ''"> and t.resource_type = #{resourceType}</if>
            <if test="status != null and status != ''"> and t.status = #{status}</if>
            <if test="params.scopeDeptId != null">
                and exists (
                    select 1
                    from edu_course c
                    where c.course_id = t.course_id
                      and c.dept_id = #{params.scopeDeptId}
                      and (c.del_flag is null or c.del_flag = '0')
                )
            </if>
            <if test="params.scopeTeacherUserId != null">
                and exists (
                    select 1
                    from edu_course_teacher ct
                    where ct.course_id = t.course_id
                      and ct.teacher_user_id = #{params.scopeTeacherUserId}
                )
            </if>
            <if test="params.scopeStudentUserId != null">
                and exists (
                    select 1
                    from edu_course_enrollment e
                    where e.course_id = t.course_id
                      and e.student_user_id = #{params.scopeStudentUserId}
                )
            </if>
        </where>
        order by t.resource_id desc
    </select>

    <select id="selectEduCourseResourceByResourceId" parameterType="Long" resultMap="EduCourseResourceResult">
        <include refid="selectEduCourseResourceVo"/>
        where t.resource_id = #{resourceId}
          and (t.del_flag is null or t.del_flag = '0')
    </select>

    <insert id="insertEduCourseResource" parameterType="com.ruoyi.system.domain.education.EduCourseResource" useGeneratedKeys="true" keyProperty="resourceId">
        insert into edu_course_resource
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseId != null">course_id,</if>
            <if test="chapterId != null">chapter_id,</if>
            <if test="resourceTitle != null">resource_title,</if>
            <if test="resourceType != null">resource_type,</if>
            <if test="fileName != null">file_name,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="fileSuffix != null">file_suffix,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="downloadCount != null">download_count,</if>
            <if test="uploadUserId != null">upload_user_id,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseId != null">#{courseId},</if>
            <if test="chapterId != null">#{chapterId},</if>
            <if test="resourceTitle != null">#{resourceTitle},</if>
            <if test="resourceType != null">#{resourceType},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="fileSuffix != null">#{fileSuffix},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="downloadCount != null">#{downloadCount},</if>
            <if test="uploadUserId != null">#{uploadUserId},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateEduCourseResource" parameterType="com.ruoyi.system.domain.education.EduCourseResource">
        update edu_course_resource
        <trim prefix="SET" suffixOverrides=",">
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="chapterId != null">chapter_id = #{chapterId},</if>
            <if test="resourceTitle != null">resource_title = #{resourceTitle},</if>
            <if test="resourceType != null">resource_type = #{resourceType},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="fileSuffix != null">file_suffix = #{fileSuffix},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="downloadCount != null">download_count = #{downloadCount},</if>
            <if test="uploadUserId != null">upload_user_id = #{uploadUserId},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where resource_id = #{resourceId}
    </update>

    <delete id="deleteEduCourseResourceByResourceId" parameterType="Long">
        delete from edu_course_resource where resource_id = #{resourceId}
    </delete>

    <delete id="deleteEduCourseResourceByResourceIds" parameterType="long">
        delete from edu_course_resource where resource_id in
        <foreach item="resourceId" collection="array" open="(" separator="," close=")">
            #{resourceId}
        </foreach>
    </delete>
</mapper>
